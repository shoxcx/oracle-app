{
  "name": "lol-tracker",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "main": "electron_app/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": ".\\node_modules\\electron\\dist\\electron.exe .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && npm run electron\"",
    "build:win": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.oracle.app",
    "productName": "Oracle",
    "artifactName": "Oracle_Installer_${version}.exe",
    "icon": "electron_app/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "shoxcx",
        "repo": "oracle-app"
      }
    ],
    "files": [
      "dist/**/*",
      "electron_app/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "electron_app/icon.png"
    },
    "nsis": {
      "oneClick": true
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "active-win": "^8.2.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.7.3",
    "framer-motion": "^12.23.26",
    "jsdom": "^28.1.0",
    "league-connect": "^6.0.0-rc13",
    "lucide-react": "^0.562.0",
    "python-shell": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "31.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  }
}